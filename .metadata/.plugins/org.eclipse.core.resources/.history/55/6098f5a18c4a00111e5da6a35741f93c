
public class NumerosImpares {
	
	//Indica si un numero es par o impar
	//ENTRADA -> n (numero)
	//SALIDA -> PAR o IMPART
	public static void main(String arg[]) {
		
		//ASUMIMOS QUE n es la entrada
		//tipo + NOMBRE_UNICO
		int n = 4;
		int x;
		
		//VARIABLE DONDE QUEREMOS GUARDAR = EL VALOR/RSULTADO
		x = n%2;
		
		//if (condicion a checar)
		if(x == 0) {
			//se ejecuta lo de adentro solo si la condcion es verdadera
			System.out.println("Par");
		}else {
			//	si no se cumple se a esta parte del codigo
			System.out.println("Impar");
		}
		
		//independiemte mente de que ejecutemos la condicon verdadera o la falsa
		//la ejeucion sigue aqui
		
		
		System.exit(0);
	}
	

}
