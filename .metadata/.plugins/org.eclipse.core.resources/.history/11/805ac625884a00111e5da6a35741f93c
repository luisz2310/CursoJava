
public class NumeroMayor {
	
	
	//ENTRADA N Y M
	//SALIDA "N ES MAYOR" "M ES MAYOR" "SON IGUALES"
	public static void main(String arg[]) {
		
		int n = 1;
		int m = 1;
		
		
		//en este casO
		//las CONDCIONES SE TODAS LAS CONDCIONES
		if(n>m) {
			System.out.println("N ES MAYOR");
		}
		if(n<m) {
			System.out.println("M ES MAYOR");
		}
		if(n==m) {
			System.out.println("son iguales");
		}
		
		
		//EN ESTE CASO
		//LAS CODCIONES SE EVUAL DE ARRIBA A ABAJA Y 
		//SOLO EJECUTO LA QUE SE CUMPLE Y LAS QUE QUEDEN POR DEBAJO YA NO SE EVALUAL
		if(n>m) {
			System.out.println("N ES MAYOR");
		}else if(n<m) {
			System.out.println("M ES MAYOR");	
		}else if(m==n) {
			System.out.println("son iguales");
		}
		
		//porque es imporante
		//quero saber si m o n es mayor que z y si lo es imprimos la letra si es igual imprimox Z + letra
		int z = 1;
		if(z<n) {
			System.out.println("N");
		}
		if(z<m) {
			System.out.println("M");
		}
		if(z == m) {
			System.out.println("ZM");
		}
		if(z == n) {
			System.out.println("ZN");
		}
		
	}

}
